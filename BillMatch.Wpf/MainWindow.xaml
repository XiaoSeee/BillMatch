<Window x:Class="BillMatch.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BillMatch.Wpf"
        xmlns:vm="clr-namespace:BillMatch.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="BillMatch - 账单对账工具" Height="600" Width="1100"
        Icon="Resources/AppIcon.ico"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="文件上传" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    
                    <!-- Qianji File -->
                    <Button Content="选择钱迹导出文件" Command="{Binding SelectQianjiFileCommand}" Padding="10,5" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding QianjiFileName, TargetNullValue='未选择文件'}" 
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding QianjiFileName}"
                               Foreground="Gray" FontSize="12" Margin="0,0,0,15"/>

                    <!-- Bill File -->
                    <Button Content="选择银行账单文件" Command="{Binding SelectBillFileCommand}" Padding="10,5" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding BillFileName, TargetNullValue='未选择文件'}" 
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding BillFileName}"
                               Foreground="Gray" FontSize="12" Margin="0,0,0,20"/>

                    <Separator Margin="0,0,0,20"/>

                    <TextBlock Text="对账设置" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <!-- Date Range -->
                    <TextBlock Text="开始日期" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,0,10"/>

                    <TextBlock Text="结束日期" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Margin="0,0,0,10"/>

                    <!-- Target Card -->
                    <TextBlock Text="目标卡号 (后四位)" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TargetCard}" Padding="5" Margin="0,0,0,10"/>

                    <!-- Tolerance -->
                    <TextBlock Text="日期容差 (天)" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="0" Maximum="10" Value="{Binding DaysTolerance}" 
                                TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DaysTolerance}" Margin="10,0,0,0" 
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Column Mapping Expander -->
                    <Expander Header="列映射配置" Margin="0,0,0,20" IsExpanded="False">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="钱迹文件 (Excel列名如A,B,C...)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="日期:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding QianjiDateColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Text="金额:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding QianjiAmountColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Text="账户1:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding QianjiAccount1Column}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Text="账户2:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding QianjiAccount2Column}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Text="描述:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding QianjiDescriptionColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>
                            </Grid>

                            <TextBlock Text="账单文件 (Excel列名如A,B,C...)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="日期:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BillDateColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Text="金额:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BillAmountColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Text="卡号:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BillCardColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Text="描述:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BillDescriptionColumn}" Margin="0,0,0,5" Width="40" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Action Button -->
                    <Button Content="开始对账" Command="{Binding StartMatchCommand}" 
                            Padding="10" FontSize="14" FontWeight="Bold" 
                            Background="#007ACC" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Column="1" Margin="10">
            <TabItem Header="漏记账单">
                <DataGrid ItemsSource="{Binding UnmatchedBills}" AutoGenerateColumns="False" 
                          IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=C2}" Width="100"/>
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="卡号" Binding="{Binding CardNumber}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="已匹配">
                <DataGrid ItemsSource="{Binding MatchedPairs}" AutoGenerateColumns="False" 
                          IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="账单日期" Binding="{Binding BillTransaction.Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="记账日期" Binding="{Binding QianjiTransaction.Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding BillTransaction.Amount, StringFormat=C2}" Width="100"/>
                        <DataGridTextColumn Header="账单描述" Binding="{Binding BillTransaction.Description}" Width="*"/>
                        <DataGridTextColumn Header="记账描述" Binding="{Binding QianjiTransaction.Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="多余记账">
                <DataGrid ItemsSource="{Binding UnmatchedQianji}" AutoGenerateColumns="False" 
                          IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=C2}" Width="100"/>
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="账户1" Binding="{Binding Account1}" Width="100"/>
                        <DataGridTextColumn Header="账户2" Binding="{Binding Account2}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="运行日志">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="复制日志" Command="{Binding CopyLogCommand}" Padding="10,5" Margin="0,0,8,0"/>
                        <Button Content="清空日志" Command="{Binding ClearLogCommand}" Padding="10,5"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding LogText}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
